<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>لوحة تحكم السيت الخاص بي</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="dashboard">
        <header>
            <h1>التحكم في السيت الذكي</h1>
            <p id="status">الحالة: متصل</p>
        </header>

        <main class="controls-grid">
            <!-- التحكم في الإضاءة -->
            <section class="card">
                <h3>الإضاءة المحيطة</h3>
                <input type="color" id="rgb-picker" value="#ff0000">
                <button onclick="updateLight()">تطبيق اللون</button>
            </section>

            <!-- التحكم في الصوت -->
            <section class="card">
                <h3>مستوى الصوت</h3>
                <input type="range" min="0" max="100" value="50" class="slider" id="volume-slider">
                <span id="vol-value">50%</span>
            </section>

            <!-- أزرار الاختصارات -->
            <section class="card">
                <h3>أوضاع سريعة</h3>
                <div class="btn-group">
                    <button class="mode-btn" onclick="setMode('Gaming')">وضع الألعاب</button>
                    <button class="mode-btn" onclick="setMode('Work')">وضع العمل</button>
                </div>
            </section>
        </main>
    </div>
    <script src="script.js"></script>
</body>
</html>
